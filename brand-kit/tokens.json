{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "middleleap": {
    "color": {
      "ink": {
        "0": { "$type": "color", "$value": "#080808", "$description": "page background" },
        "1": { "$type": "color", "$value": "#101010", "$description": "raised surface" },
        "2": { "$type": "color", "$value": "#181817", "$description": "card" },
        "3": { "$type": "color", "$value": "#232321", "$description": "hover surface" },
        "4": { "$type": "color", "$value": "#33322F", "$description": "strong border" },
        "border": { "$type": "color", "$value": "#1E1E1C" }
      },
      "bone": {
        "0": { "$type": "color", "$value": "#ECE9E1", "$description": "headline" },
        "1": { "$type": "color", "$value": "#DEDBD4", "$description": "body / brand bone" },
        "2": { "$type": "color", "$value": "#A8A59E", "$description": "secondary" },
        "3": { "$type": "color", "$value": "#87847D", "$description": "caption; AA >=4.8:1 all surfaces" },
        "4": { "$type": "color", "$value": "#4A4945", "$description": "disabled only" }
      },
      "paper": {
        "0": { "$type": "color", "$value": "#F7F5EF", "$description": "light-mode page" },
        "1": { "$type": "color", "$value": "#F0EDE5", "$description": "light-mode raised surface" },
        "2": { "$type": "color", "$value": "#E8E4DB", "$description": "light-mode card" },
        "3": { "$type": "color", "$value": "#DED8CC", "$description": "light-mode hover surface" },
        "4": { "$type": "color", "$value": "#BDB6AA", "$description": "light-mode strong border" },
        "border": { "$type": "color", "$value": "#D4CEC2" },
        "text0": { "$type": "color", "$value": "#1B1B1B", "$description": "light-mode headline" },
        "text1": { "$type": "color", "$value": "#2B2925", "$description": "light-mode body" },
        "text2": { "$type": "color", "$value": "#4D4942", "$description": "light-mode secondary" },
        "text3": { "$type": "color", "$value": "#67635C", "$description": "light-mode caption" },
        "text4": { "$type": "color", "$value": "#A09A90", "$description": "light-mode disabled only" }
      },
      "ember": {
        "300": { "$type": "color", "$value": "#F58F55" },
        "400": { "$type": "color", "$value": "#F0722E", "$description": "hover / eyebrow" },
        "500": { "$type": "color", "$value": "#E65C2D", "$description": "brand core / CTA" },
        "600": { "$type": "color", "$value": "#CE451B", "$description": "text on light" },
        "700": { "$type": "color", "$value": "#A83614", "$description": "small accent text on paper surfaces" },
        "onEmber": { "$type": "color", "$value": "#110D0A", "$description": "text on ember-500 CTA fills (AA 5.46:1)" }
      },
      "semantic": {
        "positive": { "$type": "color", "$value": "#5FA671" },
        "positiveDim": { "$type": "color", "$value": "#5FA67124", "$description": "14% tint bg" },
        "caution": { "$type": "color", "$value": "#D9A03C", "$description": "gold, never ember" },
        "cautionDim": { "$type": "color", "$value": "#D9A03C24" },
        "critical": { "$type": "color", "$value": "#D64545", "$description": "fills/borders only" },
        "criticalText": { "$type": "color", "$value": "#E06060", "$description": "red as text" },
        "criticalDim": { "$type": "color", "$value": "#D6454524" },
        "info": { "$type": "color", "$value": "#5D8FA6" },
        "infoDim": { "$type": "color", "$value": "#5D8FA624" },
        "emberDim": { "$type": "color", "$value": "#E65C2D24" },
        "dangerButtonBg": { "$type": "color", "$value": "#C43B3B" }
      }
    },
    "gradient": {
      "emberMark": {
        "$type": "gradient",
        "$value": [
          { "color": "#F0722E", "position": 0 },
          { "color": "#CE451B", "position": 1 }
        ],
        "$description": "135deg. THE MARK ONLY — never UI."
      }
    },
    "font": {
      "display": { "$type": "fontFamily", "$value": ["Instrument Serif", "Georgia", "serif"], "$description": "weight 400 only; accent em = italic ember" },
      "body": { "$type": "fontFamily", "$value": ["DM Sans", "Arial", "sans-serif"] },
      "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "monospace"], "$description": "buttons, labels, data; uppercase letterspaced" }
    },
    "fontSize": {
      "hero": { "$type": "dimension", "$value": "76px", "$description": "clamp(44px,6vw,76px)" },
      "h1": { "$type": "dimension", "$value": "42px" },
      "h2": { "$type": "dimension", "$value": "30px" },
      "h3": { "$type": "dimension", "$value": "22px" },
      "body": { "$type": "dimension", "$value": "16px" },
      "small": { "$type": "dimension", "$value": "14px" },
      "caption": { "$type": "dimension", "$value": "12.5px" }
    },
    "space": {
      "1": { "$type": "dimension", "$value": "4px" },
      "2": { "$type": "dimension", "$value": "8px" },
      "3": { "$type": "dimension", "$value": "12px" },
      "4": { "$type": "dimension", "$value": "16px" },
      "5": { "$type": "dimension", "$value": "24px" },
      "6": { "$type": "dimension", "$value": "32px" },
      "7": { "$type": "dimension", "$value": "48px" },
      "8": { "$type": "dimension", "$value": "64px" },
      "9": { "$type": "dimension", "$value": "96px" }
    },
    "radius": {
      "ui": { "$type": "dimension", "$value": "0px", "$description": "buttons, inputs, cards, tables, modals" },
      "chip": { "$type": "dimension", "$value": "2px" },
      "pill": { "$type": "dimension", "$value": "999px", "$description": "toggle track only" },
      "mark": { "$type": "dimension", "$value": "16%", "$description": "pivot glyphs only" }
    },
    "duration": {
      "fast": { "$type": "duration", "$value": "120ms" },
      "base": { "$type": "duration", "$value": "200ms" },
      "leap": { "$type": "duration", "$value": "400ms", "$description": "any 45deg pivot" }
    },
    "easing": {
      "out": { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] },
      "leap": { "$type": "cubicBezier", "$value": [0.34, 1.3, 0.4, 1], "$description": "pivots only — overshoot is the landing" }
    }
  }
}
